{
  "name": "vscode-claude-usage",
  "displayName": "Claude Usage",
  "description": "Display Claude Code usage limits in the VS Code status bar",
  "version": "0.1.0",
  "publisher": "smanettu",
  "author": "Vincenzo Vitale",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/smanettu/vscode-claude-usage"
  },
  "homepage": "https://github.com/smanettu/vscode-claude-usage#readme",
  "bugs": {
    "url": "https://github.com/smanettu/vscode-claude-usage/issues"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "os": ["darwin"],
  "categories": ["Other"],
  "keywords": ["claude", "anthropic", "ai", "usage", "status-bar", "rate-limit"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-usage.refresh",
        "title": "Claude Usage: Refresh"
      },
      {
        "command": "claude-usage.silentRefresh",
        "title": "Claude Usage: Silent Refresh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
