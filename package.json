{
  "name": "vscode-claude-usage",
  "displayName": "Claude Usage",
  "description": "Display Claude Code usage limits in the VS Code status bar",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-usage.refresh",
        "title": "Claude Usage: Refresh"
      },
      {
        "command": "claude-usage.silentRefresh",
        "title": "Claude Usage: Silent Refresh"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
